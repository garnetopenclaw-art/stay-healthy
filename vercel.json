{
  "version": 2,
  "builds": [
    {
      "src": "stay-healthy-app.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "stay-healthy-app.py"
    },
    {
      "src": "/(.*)\\.(html|css|js)$",
      "dest": "/$1.$2"
    },
    {
      "src": "/",
      "dest": "log-app.html"
    }
  ],
  "env": {
    "TWILIO_ACCOUNT_SID": "@twilio_account_sid",
    "TWILIO_AUTH_TOKEN": "@twilio_auth_token",
    "TWILIO_PHONE": "@twilio_phone",
    "AIRTABLE_TOKEN": "@airtable_token",
    "BASE_ID": "@base_id"
  }
}
