{
  "version": 2,
  "builds": [
    {
      "src": "stay-healthy-app.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "stay-healthy-app.py"
    },
    {
      "src": "/(.*)\\.(html|css|js)$",
      "dest": "/$1.$2"
    },
    {
      "src": "/",
      "dest": "log-app.html"
    }
  ]
}
